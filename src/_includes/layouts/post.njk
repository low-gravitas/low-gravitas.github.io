---
layout: layouts/base.njk
---

<article class="post" itemscope itemtype="https://schema.org/BlogPosting">
  <header class="post-header">
    <h1 itemprop="headline">{{ title }}</h1>
    {% if description %}<p class="post-description" itemprop="description">{{ description }}</p>{% endif %}
    <div class="post-meta">
      <time datetime="{{ date | htmlDateString }}" itemprop="datePublished">{{ date | readableDate }}</time>
      {% if author %}<span class="post-author" itemprop="author">by {{ author }}</span>{% endif %}
      <span class="post-reading-time">{{ content | readingTime }}</span>
    </div>
  </header>

  <div class="prose post-content" itemprop="articleBody">
    {{ content | safe }}
  </div>

  <footer class="post-footer">
    <a href="/blog/" class="back-link">All posts</a>
  </footer>
</article>
