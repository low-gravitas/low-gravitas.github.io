<div class="hero">
  <h1>Low Gravitas Zen</h1>
  <p class="tagline">A warm, low-blue-light color theme for editors and terminals. Dark and light variants with WCAG AA contrast.</p>
  <div class="actions">
    <a class="btn primary" href="/vendor/low-gravitas-zen.css"><span class="lg" aria-hidden="true">&#xF019;</span> Download CSS Tokens</a>
    <a class="btn" href="https://github.com/low-gravitas/low-gravitas-zen-theme"><span class="lg" aria-hidden="true">&#xF09B;</span> View on GitHub</a>
  </div>
</div>

<div class="demo-section">
  <div class="demo-header">
    <h2>Palette</h2>
    <button class="demo-toggle" aria-label="Toggle demo theme"><span class="demo-toggle-label">Light</span></button>
  </div>
  <div class="demo" data-theme="dark">
    <div class="swatches fade-in">
{%- set paletteNames = ["black", "red", "green", "yellow", "blue", "magenta", "cyan", "white", "bright-black", "bright-red", "bright-green", "bright-yellow", "bright-blue", "bright-magenta", "bright-cyan", "bright-white", "bg-deep", "bg-mid", "bg-raised", "selection", "cursor", "accent"] -%}
{%- for name in paletteNames -%}
{%- set darkHex = palette.dark.palette[name] -%}
{%- set lightHex = palette.light.palette[name] -%}
{%- set varName = "lgz-" + name -%}
<div class="swatch" style="background: var(--{{ varName }}); --label-dark: {{ darkHex | contrastLabel }}; --label-light: {{ lightHex | contrastLabel }};" data-dark="{{ darkHex }}" data-light="{{ lightHex }}"><span>{{ name }}</span></div>
{%- endfor %}
    </div>
  </div>
</div>

