---
layout: layouts/base.njk
title: Low Gravitas Symbol Font
description: A comprehensive symbol font combining glyphs from Nerd Fonts, Font Awesome, Material Design, Codicons, and more — all in a single font file.
bodyClass: demo-symbol-font
extraCss: /css/symbol-font.css
---

<section class="hero">
  <div class="hero-icons" aria-hidden="true">
    <span>&#xE702;</span><span>&#xE711;</span><span>&#xE900;</span>
    <span>&#xF121;</span><span>&#xEA73;</span><span>&#xF413;</span>
  </div>
  <h1>Low Gravitas Symbols</h1>
  <span class="badge badge--version" id="version" data-version="{{ site.versions.symbolFont }}"></span>
  <p class="tagline">
    A comprehensive symbol font combining glyphs from Nerd Fonts, Font Awesome,
    Material Design, Codicons, Devicons, Weather Icons, and more — all in a
    single font file for terminals, editors, and the web.
  </p>
  <div class="actions">
    <a class="btn btn--primary iri-rim" href="https://github.com/low-gravitas/low-gravitas-symbol-font/releases/latest">
      <span class="lg" aria-hidden="true">&#xF019;</span> Download Font
    </a>
    <a class="btn iri-rim" href="/symbol-font/browser/">
      <span class="lg" aria-hidden="true">&#xF002;</span> Browse Glyphs
    </a>
    <a class="btn iri-rim" href="/symbol-font/changelog/">
      <span class="lg" aria-hidden="true">&#xF017;</span> Changelog
    </a>
    <a class="btn iri-rim" href="https://github.com/low-gravitas/low-gravitas-symbol-font">
      <span class="lg" aria-hidden="true">&#xF09B;</span> View on GitHub
    </a>
  </div>
</section>

<div class="features-grid">
  <div class="card card--feature">
    <span class="card-icon lg" aria-hidden="true">&#xF413;</span>
    <h3>11,800+ Glyphs</h3>
    <p>Icons from 15 popular sets, merged into a single unified font.</p>
  </div>
  <div class="card card--feature">
    <span class="card-icon lg" aria-hidden="true">&#xEA73;</span>
    <h3>CSS Subset Builder</h3>
    <p>Pick the icons you need and download a minimal CSS stylesheet.</p>
  </div>
  <div class="card card--feature">
    <span class="card-icon lg" aria-hidden="true">&#xF489;</span>
    <h3>Terminal Ready</h3>
    <p>Designed for monospaced environments — terminals, editors, and status lines.</p>
  </div>
</div>

{% if glyphChangelog | length %}
{% set latest = glyphChangelog[0] %}
<section class="whats-new">
  <a class="whats-new-link" href="/symbol-font/changelog/">
    <div class="wn-meta">
      <span class="wn-label">What's new</span>
      <span class="badge">{{ latest.version }}</span>
      {% if latest.summary.added %}<span class="summary-pill summary-pill--added">+{{ latest.summary.added }}</span>{% endif %}
      {% if latest.summary.removed %}<span class="summary-pill summary-pill--removed">−{{ latest.summary.removed }}</span>{% endif %}
      {% if latest.summary.renamed %}<span class="summary-pill summary-pill--renamed">~{{ latest.summary.renamed }}</span>{% endif %}
    </div>
    <div class="wn-glyphs">
      {% for g in latest.preview.added %}
      <span class="wn-chip" title="{{ g.name }} · U+{{ g.hex }}">
        <span class="lg wn-chip-glyph" aria-hidden="true">{{ g.char }}</span>
        <span class="wn-chip-name">{{ g.name }}</span>
      </span>
      {% endfor %}
      {% for g in latest.preview.renamed %}
      <span class="wn-chip wn-chip--renamed" title="{{ g.old_name }} → {{ g.new_name }} · U+{{ g.hex }}">
        <span class="lg wn-chip-glyph" aria-hidden="true">{{ g.char }}</span>
        <span class="wn-chip-name"><del>{{ g.old_name }}</del><span class="wn-arrow" aria-hidden="true">→</span>{{ g.new_name }}</span>
      </span>
      {% endfor %}
    </div>
    <span class="wn-cta">Full changelog →</span>
  </a>
</section>
{% endif %}

<section class="sets-preview">
  <h2>Included Icon Sets</h2>
  <div class="sets-grid" id="sets-grid"></div>
</section>

<script src="/js/symbol-font-landing.js" defer></script>
