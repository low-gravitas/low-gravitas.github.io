---
permalink: /blog/feed.xml
eleventyExcludeFromCollections: true
layout: false
tags: []
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en">
  <title>Low Gravitas Blog</title>
  <subtitle>Notes on Low Gravitas projects, software development, and things that catch my attention.</subtitle>
  <link href="{{ site.url }}/blog/feed.xml" rel="self"/>
  <link href="{{ site.url }}/blog/"/>
  <updated>{% if collections.posts.length %}{{ collections.posts | getNewestCollectionItemDate | dateToRfc3339 }}{% else %}{{ site.buildTime }}{% endif %}</updated>
  <id>{{ site.url }}/blog/</id>
  <author>
    <name>{{ site.author }}</name>
  </author>
  {% for post in collections.posts | reverse %}
  <entry>
    <title>{{ post.data.title }}</title>
    <link href="{{ site.url }}{{ post.url }}"/>
    <updated>{{ post.date | dateToRfc3339 }}</updated>
    <id>{{ site.url }}{{ post.url }}</id>
    {% if post.data.description %}<summary>{{ post.data.description }}</summary>{% endif %}
    <content type="html">{{ post.templateContent | htmlToAbsoluteUrls(site.url + post.url) }}</content>
  </entry>
  {% endfor %}
</feed>
